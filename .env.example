# MangaMotive Python Agentic Worker Pipeline Configuration

# Ollama Local Runtime (Optimized for Raspberry Pi 5 8GB)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_DEFAULT_MODEL=gemma:2b
OLLAMA_TIMEOUT_SECONDS=120

# Contentful Management API
CONTENTFUL_MANAGEMENT_TOKEN=cfp_your_management_token_here
CONTENTFUL_SPACE_ID=your_space_id_here
CONTENTFUL_ENVIRONMENT_ID=master

# AnimeSchedule API
ANIMESCHEDULE_API_KEY=your_api_key_here

# Storage & Queues
DATABASE_URL=sqlite:///./data/agent_memory.db
REDIS_URL=redis://localhost:6379/0

# Agent Settings
LOG_LEVEL=INFO
DRY_RUN=True
